# ============================================================
# ContractIQ — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================


# ============================================================
# Supabase
# Get all values from: Supabase Dashboard → Settings → API
# ============================================================

# Your Supabase project URL (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anonymous/public key (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SERVER ONLY — Supabase service role key (bypasses RLS — never expose to browser)
# Used only in API routes (lib/supabase/server.ts)
SUPABASE_SERVICE_ROLE_KEY=


# ============================================================
# OpenAI
# Get from: https://platform.openai.com/api-keys
# ============================================================

# SERVER ONLY — OpenAI API key (used for key term extraction and chat)
OPENAI_API_KEY=


# ============================================================
# Feature Config (optional — defaults defined in lib/constants.ts)
# ============================================================

# Max PDF file size in MB shown in UI validation messages (default: 10)
NEXT_PUBLIC_MAX_FILE_SIZE_MB=10

# Max pages per contract shown in UI validation messages (default: 20)
NEXT_PUBLIC_MAX_PAGES=20
